# ═══════════════════════════════════════════════════════
#  JobMate — Environment Configuration
#  Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ── PostgreSQL Database ─────────────────────────────────
# Mac:     Install Postgres.app → https://postgresapp.com
# Windows: Install from https://postgresql.org/download
# Linux:   sudo apt install postgresql
DB_NAME=jobmate_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=127.0.0.1
DB_PORT=5432

# ── Django ──────────────────────────────────────────────
DJANGO_DEBUG=1
# DJANGO_SECRET_KEY=your-secret-key-change-this

# ── Email (Gmail SMTP) ──────────────────────────────────
# Optional — leave blank to use the built-in JobMate email account.
# To use your own Gmail: create a 16-char App Password at
# myaccount.google.com/apppasswords and paste it below (no spaces).
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
ENQUIRY_RECIPIENT=

# ── Razorpay ────────────────────────────────────────────
# Get keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
